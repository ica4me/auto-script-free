set_cron_keamanan() {
  SERVICE_NAME="Polaris"
  SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"
  SCRIPT_FILE="/usr/local/bin/polaris-monitor.sh"
  BACKUP_HAPROXY="/etc/haproxy/.haproxy.cfg.backup"

  echo "==> [1/3] Membuat salinan (Golden Backup) konfigurasi yang sehat..."
  if [ -f /etc/haproxy/haproxy.cfg ]; then
      cp /etc/haproxy/haproxy.cfg "$BACKUP_HAPROXY"
  fi

  echo "==> [2/3] Membuat skrip pemantau Ultra-Fast Auto-Heal..."
  cat > "$SCRIPT_FILE" << 'EOF'
#!/bin/bash

CONFIG="/etc/haproxy/haproxy.cfg"
BACKUP="/etc/haproxy/.haproxy.cfg.backup"

while true; do
    CEK_443=$(ss -tulnp | grep -w "haproxy" | grep -w "443")
    CEK_80=$(ss -tulnp | grep -w "haproxy" | grep -w "80")

    if [[ -z "$CEK_443" ]] || [[ -z "$CEK_80" ]]; then
        echo "[$(date)] Peringatan: HAProxy Port 443/80 Hilang! Melakukan Fast-Recovery..."
        
        chattr -i "$CONFIG" 2>/dev/null
        
        if [ -f "$BACKUP" ]; then
            # Timpa langsung dari memori lokal (Sangat Cepat)
            cp -f "$BACKUP" "$CONFIG"
        else
            wget -qO- https://raw.githubusercontent.com/ica4me/auto-script-free/main/fix-error/fix-proxy-nginx.sh | bash
        fi
        
        #chattr +i "$CONFIG" 2>/dev/null
        
        systemctl reload haproxy 2>/dev/null || systemctl restart haproxy
        
        systemctl reload nginx 2>/dev/null || systemctl restart nginx
        
        sleep 3
    fi
    sleep 3
done
EOF

  chmod +x "$SCRIPT_FILE"

  echo "==> [3/3] Mengonfigurasi Polaris Systemd Service..."
  cat > "$SERVICE_FILE" <<EOF
[Unit]
Description=Polaris Ultra-Fast HAProxy Monitor
After=network.target

[Service]
User=root
Type=simple
ExecStart=$SCRIPT_FILE
Restart=always
RestartSec=1
OOMScoreAdjust=-1000

[Install]
WantedBy=multi-user.target
EOF

  #systemctl daemon-reload
  #systemctl enable "$SERVICE_NAME"
  #systemctl restart "$SERVICE_NAME"
  
  #echo "✅ Polaris Ultra-Fast Auto-Heal AKTIF!"
  #echo "Salinan konfigurasi tersimpan di: $BACKUP_HAPROXY"
}

